<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="io.ringloom.samples.marketdata.sbe"
                   id="5101"
                   version="1"
                   semanticVersion="1.0.0"
                   description="RingLoom framework market data Avaje/SBE sample"
                   headerType="messageHeader"
                   byteOrder="littleEndian">
    <types>
        <composite name="messageHeader" description="SBE message header">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>
        <composite name="groupSizeEncoding" description="Repeating group dimensions">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="numInGroup" primitiveType="uint16"/>
        </composite>
    </types>

    <sbe:message name="QuoteRequest" id="3001" description="Market-data quote request" blockLength="16">
        <field name="instrumentId" id="1" type="uint16"/>
        <field name="quantity" id="2" type="uint32"/>
    </sbe:message>

    <sbe:message name="QuoteResponse" id="3002" description="Market-data quote response" blockLength="32">
        <field name="instrumentId" id="1" type="uint16"/>
        <field name="bidNanos" id="2" type="int64"/>
        <field name="askNanos" id="3" type="int64"/>
        <field name="quoteId" id="4" type="uint64"/>
    </sbe:message>
</sbe:messageSchema>
